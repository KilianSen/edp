FROM eclipse-temurin:25-jdk
ENV DEBIAN_FRONTEND=noninteractive LANG=en_US.UTF-8 LANGUAGE=en_US:en LC_ALL=en_US.UTF-8
ENV ARTEMIS_REPO_URL=https://github.com/KilianSen/Artemis.git ARTEMIS_BRANCH=feature/math/scaffold ARTEMIS_PROFILES=artemis,scheduling,core,dev
RUN set -eux; apt-get update; apt-get install -y --no-install-recommends git curl ca-certificates gnupg graphviz mysql-server mysql-client locales; sed -i 's/^# *en_US.UTF-8/en_US.UTF-8/' /etc/locale.gen; locale-gen
RUN echo '' | base64 -d > /etc/mysql/mysql.conf.d/zz-artemis.cnf
RUN echo '' | base64 -d > /entrypoint.sh; chmod +x /entrypoint.sh
RUN rm -rf /var/lib/mysql; install -d -o mysql -g mysql /var/lib/mysql
EXPOSE 5005 8080
ENTRYPOINT ["/entrypoint.sh"]
